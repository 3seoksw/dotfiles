#!/usr/bin/env zsh

FONT_FACE="JetBrainsMono Nerd Font"
PLUGIN_DIR="$HOME/.config/sketchybar/plugins"

sketchybar --bar height=32 \
    height=35 \
    color=0x66494d64 \
    margin=0 \
    sticky=on \
    padding_left=0 \
    padding_right=0 \
    notch_width=188 \
    display=main 
    #topmost=on

sketchybar --default \
    background.height=32 \
    icon.color=0xff24273a \
    icon.font="$FONT_FACE:Medium:20.0" \
    icon.padding_left=5 \
    icon.padding_right=5 \
    label.color=0xff24273a \
    label.font="$FONT_FACE:Bold:14.0" \
    label.y_offset=1 \
    label.padding_left=0 \
    label.padding_right=5


##### Adding Left Items #####

sketchybar --add item current_space left \
    --set current_space \
    background.color=0xfff5a97f \
    background.height=25 \
    background.corner_radius=5 \
    label.drawing=off \
    script="$PLUGIN_DIR/current_space.sh" \
    --subscribe current_space space_change mouse.clicked

sketchybar --add item front_app left \
    --set front_app \
    background.height=25 \
    background.color=0xffa6da95 \
    background.padding_left=10 \
    background.padding_right=0 \
    background.corner_radius=2 \
    icon.padding_left=5 \
    icon.y_offset=1 \
    label.drawing=no \
    script="$PLUGIN_DIR/front_app.sh" \
    --add item front_app.separator left \
    --set front_app.separator \
    background.color=0xff24273a \
    icon= \
    background.height=25 \
    icon.color=0xffa6da95 \
    icon.font="$FONT_FACE:Bold:17.0" \
    icon.padding_left=0 \
    icon.padding_right=0 \
    icon.y_offset=1 \
    label.drawing=no \
    --add item front_app.name left \
    --set front_app.name \
    background.height=25 \
    background.color=0xff24273a \
    background.corner_radius=1 \
    icon.drawing=off \
    label.font="$FONT_FACE:Bold:16.0" \
    label.color=0xffcad3f5 \
    label.padding_left=5 \
    label.padding_right=10 

sketchybar --add bracket front_app_bracket \
    front_app \
    front_app.separator \
    front_app.name \
    --subscribe front_app front_app_switched


##### Adding Right Items #####
sketchybar --add item clock right \
    --set clock \
    icon=󰃰 \
    icon.color=0xffed8796 \
    background.color=0xff24273a \
    background.height=25 \
    background.corner_radius=5 \
    background.padding_right=30 \
    label.color=0xffcad3f5 \
    update_freq=10 \
    script="$PLUGIN_DIR/clock.sh"

sketchybar --add item wifi right \
    --set wifi    script="$PLUGIN_DIR/wifi.sh" \
    background.color=0xff24273a \
    background.height=25 \
    background.padding_right=20 \
    background.corner_radius=5 \
    label.color=0xffcad3f5 \
    icon= \
    icon.color=0xffed8796 \
    --subscribe wifi wifi_change \

sketchybar --add item volume right \
    --set volume  script="$PLUGIN_DIR/volume.sh" \
    icon.color=0xffed8796 \
    background.color=0xff24273a \
    background.height=25 \
    background.padding_right=10 \
    background.corner_radius=5 \
    label.color=0xffcad3f5 \
    --subscribe volume volume_change \

sketchybar --add item battery right \
    --set battery script="$PLUGIN_DIR/battery.sh" \
    update_freq=120 \
    icon.color=0xffed8796 \
    background.color=0xff24273a \
    background.height=25 \
    background.padding_right=10 \
    background.corner_radius=5 \
    label.color=0xffcad3f5 \
    --subscribe battery system_woke power_source_change \

sketchybar -m --add event song_update com.apple.iTunes.playerInfo
sketchybar --add iterm music right \
    --set music script="$PLUGIN_DIR/music.sh" \
    click_script="$PLUGIN_DIR/music_click.sh" \
    label.padding_right=10 \
    icon.color=0xffed8796 \
    background.color=0xff24273a \
    background.height=25 \
    background.padding_right=10 \
    background.corner_radius=5 \
    label.color=0xffcad3f5 \
    drawing=off \
    --subscribe music song_update \

sketchybar --update
sketchybar --trigger space_change
